<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#455A64"
    android:fitsSystemWindows="true"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="COLONY COMMAND BRIDGE"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="30dp"/>

    <TextView
        android:id="@+id/tv_colony_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E1E1E"
        android:padding="16dp"
        android:textColor="#4CAF50"
        android:fontFamily="monospace"
        android:text="Scanning colony status..."
        android:layout_marginBottom="30dp"/>

    <Button
        android:id="@+id/btn_nav_recruit"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="RECRUIT NEW CREW"
        android:backgroundTint="#4CAF50"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_nav_quarters"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="VIEW QUARTERS"
        android:backgroundTint="#2196F3"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_nav_simulator"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:text="VR SIMULATOR"
        android:backgroundTint="#9C27B0"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btn_nav_mission"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:backgroundTint="#F44336"
        android:text="MISSION CONTROL" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp">

        <Button
            android:id="@+id/btn_save_game"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="SAVE DATA"
            android:backgroundTint="#4CAF50" android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btn_load_game"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:text="LOAD DATA"
            android:backgroundTint="#FF9800" android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

</LinearLayout>